# Intervalles (optionnel, valeurs par défaut dans le compose)
WEB_WATCHER_INTERVAL=15
VULN_SCANNER_INTERVAL=24
RANSOMWARE_INTERVAL=24
ALERT_INTERVAL=5

# APIs externes
SHODAN_API_KEY=your_shodan_key_here
ONYPHE_API_KEY=your_onyphe_key_here

# Telegram
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+33600000000

# Twitter/X
TWITTER_BEARER_TOKEN=your_bearer_token

# Alertes email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_FROM=cert@yourdomain.fr
ALERT_EMAIL_TO=team@yourdomain.fr

# Signal
SIGNAL_CLI_NUMBER=+33600000000
SIGNAL_CLI_GROUP_ID=group.XXXXXXXXXXXXXXXX

# Dashboard
DASHBOARD_PORT=8501